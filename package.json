{
  "name": "hopcode",
  "version": "1.0.0",
  "description": "Code from anywhere — remote dev environment access with voice input",
  "module": "src/server.ts",
  "type": "module",
  "bin": {
    "hopcode": "src/server-node.ts"
  },
  "scripts": {
    "start": "npx tsx src/server-node.ts",
    "start:tunnel": "npx tsx src/server-node.ts --tunnel",
    "dev": "npx tsx --watch src/server-node.ts",
    "test": "bun run src/test-all.ts"
  },
  "keywords": [
    "terminal",
    "web-terminal",
    "voice",
    "speech-to-text",
    "xterm",
    "pty",
    "cloudflare-tunnel",
    "remote-access",
    "remote-coding",
    "mobile-terminal",
    "hopcode"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hopcode-dev/hopcode"
  },
  "homepage": "https://github.com/hopcode-dev/hopcode",
  "author": "Jack Huang",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.2.2",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "dotenv": "^17.2.4",
    "node-pty": "^1.1.0",
    "ws": "^8.19.0"
  }
}
